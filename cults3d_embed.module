<?php

/**
 * @file
 * Cults3D Embed module.
 */

/**
 * Implements hook_theme().
 */
/**
 * Implements template_preprocess_HOOK() for cults3d_embed_card.
 */
function template_preprocess_cults3d_embed_card(&$variables) {
  if (empty($variables['logo_path'])) {
    $variables['logo_path'] = \Drupal::service('extension.list.module')->getPath('cults3d_embed') . '/images/cults3d-logo.svg';
  }
}

function cults3d_embed_theme($existing, $type, $theme, $path) {
  return [
    'cults3d_embed_card' => [
      'variables' => [
        'model_name' => NULL,
        'description_summary' => NULL,
        'download_count' => NULL,
        'likes_count' => NULL,
        'views_count' => NULL,
        'price' => NULL,
        'thumbnail_url' => NULL,
        'cults3d_url' => NULL,
        'logo_path' => NULL,
      ],
      'template' => 'cults3d-embed-card',
    ],
  ];
}
