<div class="cults3d-embed">
  <div class="thumbnail"{% if thumbnail_url %} style="background-image: url('{{ thumbnail_url }}');"{% endif %}></div>
  <div class="content">
    <div class="header">
      <h2 class="model-name" title="{{ model_name }}">{{ model_name|length > 33 ? model_name|slice(0, 30) ~ '...' : model_name }}</h2>
      <a href="{{ cults3d_url }}" target="_blank" rel="noopener" class="logo-container">
        <img class="cults3d-logo-img" src="/{{ logo_path }}" alt="Cults3D">
      </a>
    </div>
    {% if description_summary %}
    <div class="summary">{{ description_summary }}</div>
    {% endif %}
    <div class="stats-container">
      <div class="stats">
        <div class="stat">
          <svg class="stat-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M19.35 10.04C18.67 6.59 15.64 4 12 4 9.11 4 6.6 5.64 5.35 8.04 2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96zM17 13l-5 5-5-5h3V9h4v4h3z"/></svg>
          {{ download_count }}
        </div>
        <div class="stat">
          <svg class="stat-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z"/></svg>
          {{ price }}
        </div>
      </div>
      <a href="{{ cults3d_url }}" target="_blank" rel="noopener" class="view-button">View on Cults3D</a>
    </div>
  </div>
</div>
